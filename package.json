{
  "name": "git-sweep-pro",
  "displayName": "Git Sweep Pro",
  "description": "Safely detect and prune local Git branches whose remote upstream is gone — with dry-run previews, protected branches, and upstream sync.",
  "repository": {
    "url": "git+https://github.com/MAXOUXAX/git-sweep-pro",
    "type": "git"
  },
  "homepage": "https://github.com/MAXOUXAX/git-sweep-pro#readme",
  "bugs": {
    "url": "https://github.com/MAXOUXAX/git-sweep-pro/issues"
  },
  "license": "GPL-3.0-or-later",
  "publisher": "MAXOUXAX",
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "version": "1.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "branch",
    "branches",
    "prune",
    "cleanup",
    "stale branches",
    "gone upstream",
    "remote tracking",
    "delete branch",
    "scm",
    "rebase",
    "sync upstream",
    "force-with-lease",
    "housekeeping"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "git-sweep-pro.run",
        "category": "Git Sweep Pro",
        "title": "Sweep Stale Branches",
        "shortTitle": "Sweep Branches"
      },
      {
        "command": "git-sweep-pro.dryRun",
        "category": "Git Sweep Pro",
        "title": "Preview Stale Branches (Dry Run)",
        "shortTitle": "Preview Sweep"
      },
      {
        "command": "git-sweep-pro.postPullRequest",
        "category": "Git Sweep Pro",
        "title": "Post Pull Request Cleanup",
        "shortTitle": "Post-PR Cleanup"
      },
      {
        "command": "git-sweep-pro.syncWithUpstream",
        "category": "Git Sweep Pro",
        "title": "Sync Branch With Upstream",
        "shortTitle": "Sync Upstream"
      },
      {
        "command": "git-sweep-pro.syncWithUpstreamResume",
        "category": "Git Sweep Pro",
        "title": "Resume Sync With Upstream",
        "shortTitle": "Resume Sync"
      }
    ],
    "configuration": {
      "title": "Git Sweep Pro",
      "properties": {
        "gitSweepPro.defaultMode": {
          "type": "string",
          "enum": [
            "dryRun",
            "safeDelete",
            "forceDelete"
          ],
          "enumDescriptions": [
            "Only report the branches that would be deleted.",
            "Delete branches with git branch -d (refuses unmerged branches).",
            "Delete branches with git branch -D (force, even if unmerged)."
          ],
          "default": "safeDelete",
          "description": "Default execution mode presented first in the Run command's mode picker."
        },
        "gitSweepPro.protectedBranches": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Glob patterns for branches that must never be deleted (e.g. `main`, `develop`, `release/*`). `*` matches any characters and `?` matches a single character."
        },
        "gitSweepPro.autoFetchPrune": {
          "type": "boolean",
          "default": true,
          "description": "Run 'git fetch -p' before detecting stale branches. Disable to operate on the local ref state only."
        },
        "gitSweepPro.confirmBeforeDelete": {
          "type": "boolean",
          "default": true,
          "description": "Show a confirmation dialog before deleting the selected branches."
        }
      }
    }
  },  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p ./tsconfig.build.json",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test --label unit",
    "test:e2e": "npm run build && npm run compile && vscode-test --label e2e --label e2e-mr",
    "test:coverage": "npm run compile && vscode-test --label unit --coverage --coverage-output=coverage/unit --coverage-reporter=text-summary --coverage-reporter=json-summary --coverage-reporter=lcov",
    "test:e2e:coverage": "npm run build && npm run compile && vscode-test --label e2e --label e2e-mr --coverage --coverage-output=coverage/e2e --coverage-reporter=text-summary --coverage-reporter=json-summary --coverage-reporter=lcov",
    "coverage:check": "node ./scripts/check-coverage.mjs coverage/unit 85",
    "coverage:check:e2e": "node ./scripts/check-coverage.mjs coverage/e2e 0",
    "test:ci": "npm run test:coverage && npm run coverage:check",
    "package": "vsce package --no-dependencies",
    "publish:vsce": "vsce publish --no-dependencies",
    "publish:ovsx": "ovsx publish --no-dependencies",
    "semantic-release": "semantic-release"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.2.1",
    "ovsx": "^0.10.1",
    "semantic-release": "^24.2.9",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1"
  }
}
